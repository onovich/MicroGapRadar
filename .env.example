# Core
APP_URL=http://localhost:3000
NODE_ENV=development

# Auth / admin access for 48h MVP
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change-me
SESSION_SECRET=replace-with-long-random-string

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/microgap_radar
# For quick local prototype, Codex may switch to sqlite with Prisma if preferred.

# LLM provider
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini
OPENAI_REASONING_MODEL=gpt-4.1

# SERP provider adapter: choose one during implementation
SERP_PROVIDER=serpapi
SERP_API_KEY=...
DATAFORSEO_LOGIN=...
DATAFORSEO_PASSWORD=...
BRAVE_SEARCH_API_KEY=...

# Email, optional for MVP
RESEND_API_KEY=...
DAILY_DIGEST_FROM=MicroGap Radar <digest@example.com>

# Payments, placeholder for V1
STRIPE_SECRET_KEY=...
STRIPE_WEBHOOK_SECRET=...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...

# Cron protection
CRON_SECRET=replace-with-random-string
