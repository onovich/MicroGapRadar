# Required for local 48-hour MVP validation
APP_URL=http://localhost:3000
NODE_ENV=development

# Local SQLite database used by Prisma. The file is created under prisma/dev.db.
DATABASE_URL="file:./dev.db"

# Required local scan mode
# Keep this as mock for local smoke, tests, and the no-network MVP path.
SERP_PROVIDER=mock

# Local admin gate placeholders
# Used only for the single-admin local gate; production auth remains human-gated.
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change-me-local-only
SESSION_SECRET=replace-with-a-random-32-plus-character-local-secret

# Optional future LLM provider values
# Leave blank for local smoke/tests. Do not commit real keys.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_REASONING_MODEL=gpt-4.1

# Optional future SERP provider values
# Leave blank unless a human intentionally configures a paid provider later.
SERP_API_KEY=
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
BRAVE_SEARCH_API_KEY=

# Optional future email values
RESEND_API_KEY=
DAILY_DIGEST_FROM=MicroGap Radar <digest@example.com>

# Optional future payment values
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=

# Optional future cron/deployment values
CRON_SECRET=
PUBLIC_APP_URL=
DEPLOYMENT_ENV=
